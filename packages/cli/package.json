{
  "name": "@frehilm/ordna-cli",
  "version": "0.1.0",
  "description": "The `ordna` CLI and Ink-based Kanban TUI for Ordna. Re-exports the core API.",
  "license": "MIT",
  "author": "FreHilm <1584617+FreHilm@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FreHilm/ordna.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/FreHilm/ordna/tree/main/packages/cli#readme",
  "bugs": "https://github.com/FreHilm/ordna/issues",
  "keywords": ["kanban", "tui", "cli", "ordna", "tasks", "markdown"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ordna": "./dist/bin/ordna.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/bin/ordna.ts"
  },
  "dependencies": {
    "@frehilm/ordna-core": "workspace:*",
    "@frehilm/ordna-web": "workspace:*",
    "commander": "^12.1.0",
    "ink": "^5.1.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
